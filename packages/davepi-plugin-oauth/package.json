    "directory": "packages/davepi-plugin-oauth"
  },
  "keywords": [
    "davepi",
    "davepi-plugin",
    "oauth",
    "oauth2",
    "oidc",
    "auth",
    "social-login",
    "google",
    "github",
    "microsoft",
    "apple",
    "discord"
  ],
  "main": "index.js",
  "files": [
    "index.js",
    "lib",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "davepi": ">=1.0.4"
  },
  "peerDependenciesMeta": {
    "davepi": {
      "optional": false
    }
  },
  "scripts": {
    "test": "node --test test/*.test.js"
  }
