  },
  "keywords": [
    "davepi",
    "davepi-plugin",
    "agent",
    "ai",
    "llm",
    "skills",
    "learning"
  ],
  "main": "index.js",
  "files": [
    "index.js",
    "lib",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "davepi": ">=1.0.5",
    "davepi-plugin-queue": ">=0.1.0",
    "ai": "^4.0.0",
    "@ai-sdk/anthropic": "^1.0.0"
  },
  "peerDependenciesMeta": {
