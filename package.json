{
  "name": "davepi",
  "version": "1.0.5",
  "description": "Schema-driven Node.js backend that auto-generates REST + GraphQL + MCP from one schema file per resource. Built for AI agents.",
  "main": "index.js",
  "bin": {
    "davepi": "bin/davepi.js"
  },
  "files": [
    "index.js",
    "app.js",
    "bin/",
    "config/",
    "middleware/",
    "model/",
    "routes/",
    "utils/",
    "admin/dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "nodemon index.js",
    "dev": "nodemon --ignore 'swagger/*.json' index.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "install:admin": "cd admin && npm install --no-audit --no-fund",
    "build:admin": "cd admin && npm install --no-audit --no-fund && npm run build",
    "dev:admin": "cd admin && npm run dev",
    "prepublishOnly": "npm run build:admin"
  },
  "keywords": [
    "api",
    "framework",
    "backend",
    "rest",
    "graphql",
    "mcp",
    "mongoose",
    "express",
    "schema-driven",
    "ai",
    "agents",
    "model-context-protocol"
  ],
  "author": "David Baxter",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "apollo-server-express": "^3.6.3",
    "async": "^3.2.3",
    "bcryptjs": "^2.4.3",
    "chokidar": "^5.0.0",
    "cors": "^2.8.5",
    "directory-tree": "^3.0.0",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "express-rate-limit": "^8.5.1",
    "graphql-compose": "^9.0.7",
    "graphql-compose-mongoose": "^9.7.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^8.5.1",
    "lodash": "^4.17.21",
    "mongo-querystring": "^4.1.1",
    "mongoose": "^6.0.8",
    "mongoose-schema-jsonschema": "^2.0.2",
    "mongoose-timestamp": "^0.6.0",
    "mongoose-to-swagger": "^1.4.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^4.3.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^2.0.13",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3"
  },
  "nodemonConfig": {
    "ignore": [
      "swagger/*",
      "admin/*"
    ]
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/admin/",
      "/packages/",
      "/templates/",
      "/eval/"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/projik/davepi.git"
  },
  "bugs": {
    "url": "https://github.com/projik/davepi/issues"
  },
  "homepage": "https://docs.davepi.dev"
}
