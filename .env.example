# MongoDB connection string. For local development:
#   mongodb://localhost:27017/davepi
# For Atlas, get the SRV string from the cluster Connect dialog.
MONGO_URI=mongodb://localhost:27017/davepi

# Secret used to sign JWT access tokens. Generate a strong value with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
TOKEN_KEY=replace-me-with-a-long-random-string

# HTTP port the API listens on. Use PORT to override (PaaS conventions).
API_PORT=4001

# Default page size for list endpoints (?__page=N).
PAGE_SIZE=20

# Display name shown in the generated Swagger documentation.
APP_NAME=dAvePi

# development | production | test
# In production, error responses hide raw error messages and Apollo
# introspection / playground are disabled.
NODE_ENV=development

# Log level: trace | debug | info | warn | error | fatal | silent.
# Defaults to "info" outside tests. Pretty output in dev, JSON in prod.
LOG_LEVEL=info

# Hot-reload schema files in dev. When set to "true" AND NODE_ENV is not
# "production", chokidar watches schema/versions/** and the server picks
# up adds / changes / deletes without restarting. Disabled by default
# even in dev so it's an explicit opt-in.
HOT_RELOAD_SCHEMAS=false

# Storage backend for `type: 'File'` schema fields. Valid: local | s3.
# Defaults to local; uploads land under UPLOADS_DIR.
STORAGE_DRIVER=local
UPLOADS_DIR=./uploads

# Required only when STORAGE_DRIVER=s3. Bucket must already exist.
# AWS credentials are picked up via the standard SDK chain (env vars,
# IRSA on EKS, EC2/ECS instance metadata).
S3_BUCKET=
AWS_REGION=us-east-1
# Optional: a non-AWS S3-compatible endpoint (e.g. http://minio:9000).
# Forces path-style addressing when set.
S3_ENDPOINT=

# Comma-separated list of origins allowed to make cross-origin requests.
# Use "*" to allow any origin (not recommended in production).
# Defaults to http://localhost:3000 if unset.
CORS_ORIGINS=http://localhost:3000

# Lifetime of access tokens (vercel/ms format). Short-lived; the refresh
# token covers the long-running session.
ACCESS_TOKEN_TTL=15m

# Lifetime of refresh tokens, in days. Refresh tokens are stored hashed
# server-side and rotated on every /auth/refresh call.
REFRESH_TOKEN_TTL_DAYS=30

# Public-facing URL of the app. Used in password reset emails as the
# base for the reset link (e.g. ${APP_URL}/reset?token=...).
APP_URL=http://localhost:3000

# SMTP transport for password reset emails (and future transactional
# mail). When SMTP_HOST is unset, /auth/forgot-password logs the
# would-be email instead of sending it — useful for local dev / CI.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
