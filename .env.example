# MongoDB connection string. For local development:
#   mongodb://localhost:27017/davepi
# For Atlas, get the SRV string from the cluster Connect dialog.
MONGO_URI=mongodb://localhost:27017/davepi

# Secret used to sign JWT access tokens. Generate a strong value with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
TOKEN_KEY=replace-me-with-a-long-random-string

# HTTP port the API listens on. Use PORT to override (PaaS conventions).
API_PORT=4001

# Default page size for list endpoints (?__page=N).
PAGE_SIZE=20

# Display name shown in the generated Swagger documentation.
APP_NAME=dAvePi

# development | production | test
# In production, error responses hide raw error messages and Apollo
# introspection / playground are disabled.
NODE_ENV=development

# Log level: trace | debug | info | warn | error | fatal | silent.
# Defaults to "info" outside tests. Pretty output in dev, JSON in prod.
LOG_LEVEL=info

# Comma-separated list of origins allowed to make cross-origin requests.
# Use "*" to allow any origin (not recommended in production).
# Defaults to http://localhost:3000 if unset.
CORS_ORIGINS=http://localhost:3000

# Lifetime of access tokens (vercel/ms format). Short-lived; the refresh
# token covers the long-running session.
ACCESS_TOKEN_TTL=15m

# Lifetime of refresh tokens, in days. Refresh tokens are stored hashed
# server-side and rotated on every /auth/refresh call.
REFRESH_TOKEN_TTL_DAYS=30
