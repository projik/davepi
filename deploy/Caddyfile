# Caddyfile for self-hosted dAvePi.
#
# Caddy provisions a Let's Encrypt certificate automatically on
# first boot. The {$DOMAIN} env-var substitution picks up the
# DOMAIN value from docker-compose.prod.yml.

{$DOMAIN} {
	# Let's Encrypt email — sourced from the ACME_EMAIL env var.
	tls {$ACME_EMAIL}

	# Proxy everything to the dAvePi container. Caddy sets the
	# X-Forwarded-* headers itself; the app trusts them only
	# when TRUST_PROXY=true (set in docker-compose.prod.yml) so
	# the rate limiter accounts per real client IP instead of
	# per Caddy-container.
	reverse_proxy api:4001

	# Strict transport security — opt-in once you're confident
	# the cert provisioned cleanly. Uncomment after the first
	# successful HTTPS request.
	# header Strict-Transport-Security "max-age=31536000; includeSubDomains"

	# Hide server identification.
	header -Server
}
