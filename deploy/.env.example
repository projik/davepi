# Production env for the self-hosted Docker Compose stack at
# deploy/docker-compose.prod.yml. Copy to deploy/.env and fill in
# the values marked `<REPLACE ME>`.

# === Required ===

# Public hostname Caddy provisions a Let's Encrypt cert for.
DOMAIN=<REPLACE ME>            # e.g. api.example.com

# Email address used for Let's Encrypt registration.
ACME_EMAIL=<REPLACE ME>        # e.g. ops@example.com

# JWT signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
TOKEN_KEY=<REPLACE ME>

# === Optional ===

# Display name in the Swagger UI / log lines / _describe.
APP_NAME=acme-api

# Default page size for list endpoints (?__page=N).
PAGE_SIZE=20

# Pino log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# Comma-separated allowlist of origins for CORS. Leave unset to
# block cross-origin requests entirely.
CORS_ORIGINS=https://app.example.com

# === Observability (optional, see /operations/observability/) ===

# Set to 'true' to enable the Prometheus /_metrics endpoint.
METRICS_ENABLED=false

# Bearer token gating /_metrics. Leave blank for unauthenticated
# scraping (only safe on an internal network).
METRICS_TOKEN=
